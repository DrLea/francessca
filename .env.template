# ---------------------------------------------------------------------------
# Francessca - Environment Variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# --- Database ---
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg://francessca:francessca@db:5432/francessca

# --- JWT ---
# Generate a strong secret, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Redis (cache + rate limiting) ---
REDIS_URL=redis://redis:6379/0

# --- Anthropic (server-side only, never exposed to frontend) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- SMTP (transactional email) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@francessca.app

# --- URLs ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# --- App ---
# Comma-separated origins allowed by CORS
CORS_ORIGINS=http://localhost:3000
# Default monthly token allowance for the "free" tier
FREE_TIER_TOKEN_LIMIT=100000
# Bootstrap admin (created on first startup if it does not exist)
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Max upload size in bytes (25 MB)
MAX_UPLOAD_SIZE=26214400
# Directory where uploaded files are stored
UPLOAD_DIR=/data/uploads
# Seed the lawyer directory with fictional sample data on first startup
# (lets the directory/search UI work before you run the real scraper).
# Set to false once you're syncing real data.
USE_FAKE_LAWYERS_DB=true
